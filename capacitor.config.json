{
  "appId": "com.qsecure.app",
  "appName": "Q-Secure",
  "webDir": "frontend/build",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#8B0000",
      "showSpinner": true,
      "spinnerColor": "#FFD700"
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#8B0000"
    }
  }
}
