{
  "name": "q-secure-desktop",
  "version": "2.0.0",
  "description": "Q-Secure PQC Cryptographic Scanner - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.qsecure.app",
    "productName": "Q-Secure",
    "files": ["main.js", "../frontend/build/**/*"],
    "win": { "target": "nsis", "icon": "icon.ico" },
    "mac": { "target": "dmg", "icon": "icon.icns" },
    "linux": { "target": "AppImage", "icon": "icon.png" }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  }
}
